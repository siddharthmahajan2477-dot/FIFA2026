# ═══════════════════════════════════════════════════════════════════════════
#  FIFA World Cup 2026 Smart Stadium OS — Environment Configuration
#  Copy this file to .env and fill in real values before deployment.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development            # development | testing | staging | production
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stadium
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=
REFRESH_SECRET=
WEBHOOK_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── AI Providers ─────────────────────────────────────────────────────────────
AI_PROVIDER=google_genai            # google_genai | openai | claude | groq | mistral | deepseek
GOOGLE_GENAI_API_KEY=
GOOGLE_GENAI_MODEL=gemini-2.0-flash-exp
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# ── Football Data ─────────────────────────────────────────────────────────────
FOOTBALL_PROVIDER=api_football      # api_football | football_data | sportmonks | sportradar
FOOTBALL_API_KEY=
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io

# ── Weather ───────────────────────────────────────────────────────────────────
WEATHER_PROVIDER=open_weather       # open_weather | tomorrow_io | weather_api
WEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ── Maps / Navigation ─────────────────────────────────────────────────────────
MAPS_PROVIDER=google_maps           # google_maps | mapbox | openstreetmap
GOOGLE_MAPS_API_KEY=
MAPBOX_API_KEY=

# ── Payments ──────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe             # stripe | razorpay | paypal
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid             # sendgrid | mailgun | smtp | ses
SENDGRID_API_KEY=
MAILGUN_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@stadium.local

# ── SMS ───────────────────────────────────────────────────────────────────────
SMS_PROVIDER=twilio                 # twilio | msg91 | sns
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MSG91_API_KEY=

# ── Push Notifications ────────────────────────────────────────────────────────
PUSH_PROVIDER=firebase              # firebase | web_push
FIREBASE_SERVER_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Object Storage ────────────────────────────────────────────────────────────
STORAGE_PROVIDER=s3                 # s3 | r2 | gcs | azure | local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
GCS_BUCKET=
AZURE_STORAGE_CONNECTION_STRING=
CDN_BASE_URL=

# ── WebSocket ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8000/ws

# ── Frontend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AI_PROVIDER=google_genai
NEXT_PUBLIC_MAP_PROVIDER=google_maps
NEXT_PUBLIC_PAYMENT_PROVIDER=stripe
NEXT_PUBLIC_WEATHER_PROVIDER=open_weather
NEXT_PUBLIC_FOOTBALL_PROVIDER=api_football
NEXT_PUBLIC_USE_MOCK=false

# ── Analytics & Monitoring ───────────────────────────────────────────────────
GOOGLE_ANALYTICS_ID=
SENTRY_DSN=

# ── Media / Image Optimization ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OAuth Providers ───────────────────────────────────────────────────────────
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# Additional Enterprise Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ── Application Metadata ──────────────────────────────────────────────────
APP_NAME=FIFA World Cup 2026 Smart Stadium Operating System
APP_VERSION=1.0.0
API_VERSION=v1
DOMAIN=localhost
SSL_ENABLED=false

# ── PostgreSQL Advanced Configuration ─────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stadium
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30

# ── Redis Advanced Configuration ──────────────────────────────────────────
REDIS_PASSWORD=
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1
REDIS_SESSION_DB=2
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT / Security Configuration ──────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ISSUER=stadium-os
JWT_AUDIENCE=stadium-users
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=Lax

# ── CORS Configuration ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# ── AI Runtime Configuration ──────────────────────────────────────────────
AI_TIMEOUT_SECONDS=60
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.4
AI_STREAMING=true
AI_ENABLE_FUNCTION_CALLING=true

# ── Football API Configuration ────────────────────────────────────────────
FOOTBALL_API_TIMEOUT=20
FOOTBALL_REFRESH_INTERVAL=60

# ── Weather Configuration ─────────────────────────────────────────────────
WEATHER_REFRESH_INTERVAL=300

# ── Google Maps Configuration ─────────────────────────────────────────────
GOOGLE_MAPS_STYLE_ID=
GOOGLE_MAPS_REGION=IN

# ── Email Configuration ───────────────────────────────────────────────────
EMAIL_REPLY_TO=support@stadium.local

# ── Firebase Admin SDK ────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── File Upload Limits ────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp,avif
ALLOWED_VIDEO_TYPES=mp4,mov,webm,mkv

# ── WebSocket Configuration ───────────────────────────────────────────────
WS_HEARTBEAT_INTERVAL=30
WS_RECONNECT=true

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
ENABLE_REQUEST_LOGGING=true

# ── Monitoring ────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
METRICS_ENDPOINT=/metrics

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── Feature Flags ─────────────────────────────────────────────────────────
ENABLE_AI=true
ENABLE_CHAT=true
ENABLE_EMAIL=true
ENABLE_SMS=true
ENABLE_PUSH=true
ENABLE_ANALYTICS=true
ENABLE_MONITORING=true
ENABLE_PAYMENTS=true
ENABLE_REALTIME=true
ENABLE_MOCK_MODE=false

# ── OAuth Providers (Additional) ──────────────────────────────────────────
# X (Twitter)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Yahoo
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# ── Cloudflare R2 (CDN / Storage) ────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# ── AI Observability ──────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ── Search Engine ─────────────────────────────────────────────────────────
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# ── Vector Database ───────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=
QDRANT_URL=
QDRANT_API_KEY=

# ── OCR / Vision ──────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Translation ───────────────────────────────────────────────────────────
GOOGLE_TRANSLATE_API_KEY=

# ── Video Streaming ───────────────────────────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# ── Error / Alert Notifications ───────────────────────────────────────────
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ═══════════════════════════════════════════════════════════════════════════
# Firebase Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ── Firebase Web App (Client-side — NEXT_PUBLIC_ prefix required) ──────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin SDK (Server-side — backend only) ────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Backend Connection ───────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=

